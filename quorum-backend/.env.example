# =============================================================================
# QUORUM — plantilla de entorno (backend Laravel)
# Copia este archivo:  copy .env.example .env   (Windows PowerShell: Copy-Item)
# Luego: php artisan key:generate
# Rellena MAIL_* y RECAPTCHA_* con tus valores reales (no subas .env al repo).
# =============================================================================

APP_NAME=QUORUM
APP_ENV=local
# Déjalo vacío la primera vez; artisan key:generate lo rellena
APP_KEY=
APP_DEBUG=true
# URL pública de esta API (php artisan serve → suele ser puerto 8000)
APP_URL=http://localhost:8000

# URL del SPA Next.js (correo de reset: {FRONTEND_URL}/reset?token=...). Sin barra final.
# Si Next corre en 3001, usa http://localhost:3001
FRONTEND_URL=http://localhost:3000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Base de datos — MySQL (XAMPP / local). Crea la BD "quorum" antes de migrar.
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=quorum
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Sesión + Sanctum (SPA Next.js con cookies)
# SESSION_DOMAIN debe coincidir con el host del navegador (p. ej. localhost).
# -----------------------------------------------------------------------------
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

# Orígenes del front para cookies stateful (puerto 3001 si 3000 está ocupado)
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001,127.0.0.1:3000,127.0.0.1:3001

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# -----------------------------------------------------------------------------
# Correo — Gmail SMTP (recuperación de contraseña, etc.)
# Usa una "Contraseña de aplicación" de Google, no la contraseña de la cuenta.
# Si la app password trae espacios, ponla entre comillas: MAIL_PASSWORD="xxxx xxxx xxxx xxxx"
# No definas MAIL_SCHEME=tls (Laravel 12 / Symfony Mailer no lo acepta). Puerto 587 + smtp.gmail.com usa STARTTLS solo.
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_cuenta@gmail.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=tu_cuenta@gmail.com
MAIL_FROM_NAME="QUORUM - Sistema SENA"

# -----------------------------------------------------------------------------
# reCAPTCHA v2 — login staff (site key en el front, secret solo en el backend)
# Obtén las claves en Google reCAPTCHA admin. Ver PRD §14.1.
# -----------------------------------------------------------------------------
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# -----------------------------------------------------------------------------
# Opcional — Laravel / Vite (dejar vacío si no usas)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
